# Basic self-consistent field calculation for Silicon conventional cell
 &control
    calculation='scf'
    restart_mode='from_scratch',
    prefix='si',
    pseudo_dir = './pseudo',
    outdir='./out'
 /
 &system
    ibrav = 0,
    nat = 64,
    ntyp = 1,
    ecutwfc = 20.0
 /
 &electrons
    diagonalization='david'
    mixing_mode = 'plain'
    mixing_beta = 0.7
    conv_thr = 1.0d-8
 /

K_POINTS (automatic)
 4 4 4 1 1 1

ATOMIC_SPECIES
  Si  28.0855  Si.pbe-n-rrkjus_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
  10.8600000000  0.0000000000  0.0000000000
  0.0000000000  10.8600000000  0.0000000000
  0.0000000000  0.0000000000  10.8600000000

