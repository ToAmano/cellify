# Basic self-consistent field calculation for Silicon conventional cell
 &control
    calculation='scf'
    restart_mode='from_scratch',
    prefix='si',
    pseudo_dir = './pseudo',
    outdir='./out'
 /
 &system
    ibrav = 0, 
    nat = 8, 
    ntyp = 1,
    ecutwfc = 20.0
 /
 &electrons
    diagonalization='david'
    mixing_mode = 'plain'
    mixing_beta = 0.7
    conv_thr = 1.0d-8
 /
CELL_PARAMETERS (angstrom)
  5.43000000   0.00000000   0.00000000
  0.00000000   5.43000000   0.00000000
  0.00000000   0.00000000   5.43000000
ATOMIC_SPECIES
 Si  28.0855  Si.pbe-n-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS (crystal)
  Si   0.0   0.0   0.0
  Si   0.0   0.5   0.5
  Si   0.5   0.0   0.5
  Si   0.5   0.5   0.0
  Si   0.25  0.25  0.25
  Si   0.25  0.75  0.75
  Si   0.75  0.25  0.75
  Si   0.75  0.75  0.25
K_POINTS (automatic)
 4 4 4 1 1 1
